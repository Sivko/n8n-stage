# PostgreSQL (used by docker-compose)
POSTGRES_USER=n8n
POSTGRES_PASSWORD=change_me
POSTGRES_DB=n8n

# n8n: generate with: openssl rand -base64 32
N8N_ENCRYPTION_KEY=

# Public URLs (adjust for your domain)
N8N_HOST=localhost
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678/
N8N_EDITOR_BASE_URL=http://localhost:5678
# Set to 1+ when behind a reverse proxy (nginx, Traefik, etc.)
N8N_PROXY_HOPS=0
# MongoDB (docker service name: mongo, port 27017)
MONGO_INITDB_ROOT_USERNAME=mongo
MONGO_INITDB_ROOT_PASSWORD=change_me_mongo_root_password